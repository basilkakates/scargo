# Copy to .env for local overrides. Do not commit real secrets.
SCARGO_ENV=dev
SCARGO_HTTP_HOST=127.0.0.1
SCARGO_HTTP_PORT=8080

# Local Docker Compose defaults.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=scargo
POSTGRES_PASSWORD=change-me
POSTGRES_DB=scargo

# Production must inject an explicit secret URL outside tracked files.
# SCARGO_DATABASE_URL=postgresql://USER@HOST:PORT/DBNAME

# Optional deployed shared-link polling.
SCARGO_SHARED_LINK_INGEST=false
SCARGO_SHARED_LINK_POLL_SECONDS=3600
SCARGO_SHARED_LINK_SECRET=change-me
