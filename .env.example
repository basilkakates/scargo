# Copy to .env for local overrides. Do not commit real secrets.
SCARGO_ENV=dev
SCARGO_HTTP_HOST=127.0.0.1
SCARGO_HTTP_PORT=8080

# Local Docker Compose defaults.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=scargo
POSTGRES_PASSWORD=change-me
POSTGRES_DB=scargo

# Production must inject an explicit secret URL outside tracked files.
# SCARGO_DATABASE_URL=postgresql://USER@HOST:PORT/DBNAME

# Optional Dropbox ingest support. Leave disabled unless all values are set.
# SCARGO_DROPBOX_ENABLED=false
# DROPBOX_APP_KEY=your-dropbox-app-key
# DROPBOX_APP_SECRET=your-dropbox-app-secret
# SCARGO_BASE_URL=http://localhost:8080
# SCARGO_TOKEN_ENCRYPTION_KEY=32-byte-hex-or-base64
# SCARGO_DROPBOX_POLL_SEC=300
