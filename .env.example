# Copy to .env for local overrides. Do not commit real secrets.
SCARGO_ENV=dev
SCARGO_HTTP_HOST=127.0.0.1
SCARGO_HTTP_PORT=8080

# Local Docker Compose defaults.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=scargo
POSTGRES_PASSWORD=change-me
POSTGRES_DB=scargo

# Production must inject an explicit secret URL outside tracked files.
# SCARGO_DATABASE_URL=postgresql://USER@HOST:PORT/DBNAME

# Optional Dropbox OAuth ingest.
SCARGO_DROPBOX_ENABLED=false
DROPBOX_APP_KEY=change-me
DROPBOX_APP_SECRET=change-me
SCARGO_BASE_URL=http://localhost:8080
# Optional exact OAuth callback override when Dropbox must hit a different
# host/path than SCARGO_BASE_URL + /api/dropbox/oauth/callback.
# SCARGO_DROPBOX_REDIRECT_URI=http://localhost:8080/api/dropbox/oauth/callback
# 64 hex chars = 32-byte AES-256 key used for encrypted refresh tokens.
SCARGO_TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
SCARGO_DROPBOX_POLL_SEC=3600
